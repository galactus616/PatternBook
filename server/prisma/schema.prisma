generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// 🟣 ENUMS
//

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Priority {
  MUST_DO
  GOOD
  OPTIONAL
}

enum Status {
  NOT_STARTED
  ATTEMPTED
  SOLVED_WITH_HELP
  SOLVED_INDEPENDENTLY
  REVISED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

//
// 🟢 CORE TABLES
//

model User {
  id        String         @id @default(uuid())
  name      String?
  email     String         @unique
  password  String
  picture   String?
  provider  AuthProvider   @default(EMAIL)
  createdAt DateTime       @default(now())
  
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?

  // Subscription & Payments
  plan               Plan               @default(FREE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionId     String?            // Razorpay Subscription/Order ID
  subscriptionEndsAt DateTime?
  
  transactions       Transaction[]
  couponUsages       CouponUsage[]
  
  // Team Management
  teamId             String?
  team               Team?              @relation("TeamMembers", fields: [teamId], references: [id])
  ownedTeam          Team?              @relation("TeamOwner")

  progress  UserProgress[]
}

model Topic {
  id        String     @id @default(uuid())
  name      String     @unique

  patterns  Pattern[]
  problems  Problem[]
}

model Pattern {
  id        String       @id @default(uuid())
  name      String
  topicId   String
  topic     Topic        @relation(fields: [topicId], references: [id])

  subPatterns SubPattern[]
  problems    Problem[]

  @@unique([name, topicId])
}

model SubPattern {
  id         String    @id @default(uuid())
  name       String
  patternId  String
  pattern    Pattern   @relation(fields: [patternId], references: [id])

  problems   Problem[]

  @@unique([name, patternId])
}

model Problem {
  id            String      @id @default(uuid())
  title         String
  leetcodeId    Int?
  leetcodeUrl   String?

  difficulty    Difficulty
  priority      Priority

  order         Int         @unique
  phase         Int

  topicId       String
  topic         Topic       @relation(fields: [topicId], references: [id])

  patternId     String
  pattern       Pattern     @relation(fields: [patternId], references: [id])

  subPatternId  String
  subPattern    SubPattern  @relation(fields: [subPatternId], references: [id])
  
  hint          String?
  timeEstimate  Int?

  isPro         Boolean     @default(false)
  createdAt     DateTime    @default(now())

  progress      UserProgress[]
}

//
// 🔵 USER PROGRESS
//

model UserProgress {
  id            String    @id @default(uuid())

  userId        String
  problemId     String

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem       Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  status        Status    @default(NOT_STARTED)
  attempts      Int       @default(0)
  lastReviewed  DateTime?
  notes         String?

  updatedAt     DateTime  @updatedAt

  @@unique([userId, problemId])
}

//
// 🟠 PAYMENT & TEAMS
//

model Transaction {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  
  amount            Int      // In paise
  currency          String   @default("INR")
  status            String   // 'created', 'captured', 'failed'
  
  couponId          String?
  coupon            Coupon?  @relation(fields: [couponId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int          // Value in percentage or paise
  
  expiryDate    DateTime?
  maxUses       Int?         // Total global uses allowed
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  
  usages        CouponUsage[]
  transactions  Transaction[]
  
  createdAt     DateTime     @default(now())
}

model CouponUsage {
  id        String   @id @default(uuid())
  userId    String
  couponId  String
  user      User     @relation(fields: [userId], references: [id])
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  usedAt    DateTime @default(now())

  @@unique([userId, couponId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  
  ownerId   String   @unique
  owner     User     @relation("TeamOwner", fields: [ownerId], references: [id])
  
  members   User[]   @relation("TeamMembers")
  
  createdAt DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  type      String   // e.g., "TEAM_PLAN"
  message   String?
  createdAt DateTime @default(now())
}
