generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// 🟣 ENUMS
//

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Priority {
  MUST_DO
  GOOD
  OPTIONAL
}

enum Status {
  NOT_STARTED
  ATTEMPTED
  SOLVED_WITH_HELP
  SOLVED_INDEPENDENTLY
  REVISED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

//
// 🟢 CORE TABLES
//

model User {
  id        String         @id @default(uuid())
  name      String?
  email     String         @unique
  password  String
  picture   String?
  provider  AuthProvider   @default(EMAIL)
  plan      Plan           @default(FREE)
  createdAt DateTime       @default(now())

  orders    Order[]
  
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?

  progress  UserProgress[]
}

model Topic {
  id        String     @id @default(uuid())
  name      String     @unique

  patterns  Pattern[]
  problems  Problem[]
}

model Pattern {
  id        String       @id @default(uuid())
  name      String
  topicId   String
  topic     Topic        @relation(fields: [topicId], references: [id])

  subPatterns SubPattern[]
  problems    Problem[]

  @@unique([name, topicId])
}

model SubPattern {
  id         String    @id @default(uuid())
  name       String
  patternId  String
  pattern    Pattern   @relation(fields: [patternId], references: [id])

  problems   Problem[]

  @@unique([name, patternId])
}

model Problem {
  id            String      @id @default(uuid())
  title         String
  leetcodeId    Int?
  leetcodeUrl   String?

  difficulty    Difficulty
  priority      Priority

  order         Int         @unique
  phase         Int

  topicId       String
  topic         Topic       @relation(fields: [topicId], references: [id])

  patternId     String
  pattern       Pattern     @relation(fields: [patternId], references: [id])

  subPatternId  String
  subPattern    SubPattern  @relation(fields: [subPatternId], references: [id])
  
  hint          String?
  timeEstimate  Int?

  createdAt     DateTime    @default(now())

  progress      UserProgress[]
}

//
// 🔵 USER PROGRESS
//

model UserProgress {
  id            String    @id @default(uuid())

  userId        String
  problemId     String

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem       Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  status        Status    @default(NOT_STARTED)
  attempts      Int       @default(0)
  lastReviewed  DateTime?
  notes         String?

  updatedAt     DateTime  @updatedAt

  @@unique([userId, problemId])
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Int         // Amount in paise
  currency          String      @default("INR")
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  razorpaySignature String?
  status            OrderStatus @default(PENDING)
  plan              Plan
  couponCode        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int          // e.g., 50 for 50%, or 50000 for ₹500
  maxUses       Int?         // Null means unlimited
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
